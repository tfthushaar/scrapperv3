# The app works 100% free out of the box using DuckDuckGo — no keys needed.
#
# Optional: add a paid search API for higher quotas and more reliable results.
# If set, SerpAPI takes priority over Google CSE, which takes priority over DDG.

# ─── SerpAPI (https://serpapi.com — 100 free searches/month) ─────────────────
# SERPAPI_KEY=your_serpapi_key_here

# ─── Google Custom Search Engine ─────────────────────────────────────────────
# API key : https://console.developers.google.com
# CSE ID  : https://programmablesearchengine.google.com
# Enable "Search the entire web" in CSE settings for full coverage.
# GOOGLE_CSE_KEY=your_google_cse_api_key_here
# GOOGLE_CSE_ID=your_cse_id_here
