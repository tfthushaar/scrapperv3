# Auth controls
# AUTH_REQUIRED=true
# ALLOW_SIGNUP=true

# Optional bootstrap admin account
# APP_USERNAME=admin
# APP_PASSWORD=change-me

# Preferred deployment database for real persistence
# Example Supabase session pooler URL:
# DATABASE_URL=postgresql+psycopg://postgres.user:password@host:5432/postgres?sslmode=require

# Alternative split Postgres settings if you prefer Supabase's separate fields
# user=
# password=
# host=
# port=5432
# dbname=postgres

# Local SQLite fallback
# LEADS_DB_PATH=data/leads.db

# Optional search upgrades
# SERPAPI_KEY=your_serpapi_key_here
# GOOGLE_CSE_KEY=your_google_cse_api_key_here
# GOOGLE_CSE_ID=your_google_cse_id_here
